<Page
    x:Class="BBCLauncher.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#1E1E1E">

    <Grid Padding="48">
        <StackPanel VerticalAlignment="Center" MaxWidth="1000">
            <TextBlock Text="BBC Launcher" FontSize="42" Foreground="White" Margin="0,0,0,16" />
            <TextBlock x:Name="StageText" Text="Preparing..." FontSize="24" Foreground="#CCCCCC" Margin="0,0,0,8" />
            <TextBlock x:Name="DetailText" Text="" FontSize="18" Foreground="#888888" TextWrapping="WrapWholeWords" Margin="0,0,0,8" />
            <ProgressBar x:Name="ProgressBar" IsIndeterminate="True" Height="8" Margin="0,0,0,16" />
            <TextBlock x:Name="StatusText" Text="" FontSize="16" Foreground="#FF6B6B" TextWrapping="WrapWholeWords" />
            <TextBlock Text="Diagnostics" FontSize="18" Foreground="#CCCCCC" Margin="0,16,0,8" />
            <ScrollViewer Height="280" VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="DiagnosticsBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         MinHeight="240"
                         FontFamily="Consolas"
                         FontSize="14" />
            </ScrollViewer>
        </StackPanel>
    </Grid>
</Page>
