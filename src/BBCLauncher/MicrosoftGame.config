<?xml version="1.0" encoding="utf-8"?>
<Game configVersion="1">
  <Identity Name="BBCLauncher" Publisher="CN=Developer" Version="1.0.0.0" />
  <ShellVisuals DefaultDisplayName="BBC Launcher"
                PublisherDisplayName="Independent Developer"
                Square480x480Logo="Assets\Square480x480Logo.png"
                Square44x44Logo="Assets\Square44x44Logo.png"
                Description="Big Block Client launcher for Minecraft Java Edition on Xbox Series X"
                ForegroundText="light"
                BackgroundColor="#1E1E1E"
                SplashScreenImage="Assets\SplashScreen.png"
                StoreLogo="Assets\StoreLogo.png" />
  <Resources>
    <Resource Name="TitleId">00000000</Resource>
    <Resource Name="XboxLiveCreatorsTitle">true</Resource>
  </Resources>
  <ExecutableList>
    <Executable Name="BBCLauncher.exe" TargetDeviceFamily="Xbox" />
  </ExecutableList>
</Game>
