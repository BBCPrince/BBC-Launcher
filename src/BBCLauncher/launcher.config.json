{
    "MicrosoftClientId":  "REPLACE_WITH_AZURE_APP_CLIENT_ID",
    "TargetMinecraftVersion":  "1.21.1",
    "JavaRuntimeVersion":  "21",
    "ManifestUrl":  "https://example.invalid/manifest.json",
    "LocalManifestFileName":  "download-manifest.json",
    "EnableResolutionPicker":  true,
    "IncludeStandardControllerMod":  true,
    "IncludeXboxUiMod":  false,
    "GraphicsProbeMode":  false,
    "SkipAuthenticationForDebug":  false,
    "SkipDownloadsForDebug":  false,
    "RunGraphicsProbeBeforeLaunch":  false,
    "EmbeddedJvmProbeMode":  false,
    "RunEmbeddedJvmProbeBeforeLaunch":  false,
    "EmbeddedMinecraftLaunchMode":  true,
    "SafeLaunchDiagnostics":  true,
    "NativeLibrariesToProbe":  [

                               ],
    "GraphicsBridgeDllName":  "graphics_bridge.dll",
    "UseXboxLog4jConfig":  true,
    "StageBundledNativeShims":  true,
    "XboxLog4jConfigResource":  "Resources/log4j2-xbox.xml",
    "BundledNativeShims":  [
                               "Ole32.dll",
                               "Pdh.dll",
                               "graphics_bridge.dll"
                           ],
    "RunPathProbeBeforeLaunch":  true,
    "PathProbeJarPackagePath":  "native/XboxPathProbe.jar",
    "PathProbeTimeoutSeconds":  25,
    "PathProbeExtraCandidates":  [

                                 ],
    "AutoSelectGameDirectory":  true,
    "GameDirectoryOverride":  "",
    "UseJdkPatch":  true,
    "JdkPatchJarPackagePath":  "native/xbox-jdk-patch.jar",
    "ApplyJdkPatchToProbe":  true,
    "UseXboxGlfwStub":  true,
    "XboxGlfwDllPackagePath":  "native/xbox-glfw.dll",
    "UseCustomOpenGlProvider":  true,
    "OpenGlProvider":  "mesa-uwp",
    "GraphicsRuntimeMode":  "xboxone",
    "UseXboxOpenGlStub":  false,
    "XboxOpenGlDllPackagePath":  "native/xbox-opengl.dll",
    "MesaUwpRuntimePackagePath":  "native/mesa-uwp",
    "MesaUwpOpenGlDllPackagePath":  "native/mesa-uwp/opengl32.dll",
    "EnableMesaUwpD3D12Environment":  true,
    "EnableMesaCoreWindowProbe":  false,
    "NativeCoreWindowHostMode":  true,
    "NativeCoreWindowHostDirectMesaOpenGl":  true,
    "NativeCoreWindowHostFatalSurfaceFailure":  true,
    "Glon12RuntimePackagePath":  "native/glon12",
    "Glon12OpenGlDllPackagePath":  "native/glon12/opengl32.dll",
    "EnableGlon12D3D12Environment":  true,
    "Glon12D3D12AdapterName":  "",
    "UseXboxOpenAlStub":  true,
    "XboxOpenAlDllPackagePath":  "native/xbox-openal.dll",
    "EnableGameHostPresentation":  false,
    "SoftwareRenderingFallback":  false,
    "GraphicsBackend":  "d3d12-opengl",
    "AudioBackend":  "xbox",
    "InputBackend":  "gamepad-bridge",
    "DefaultHeapMegabytes":  4096,
    "JavaExecutableRelativePath":  "runtime/jre/bin/java.exe",
    "GameDirectoryName":  "game",
    "AssetsDirectoryName":  "assets",
    "LogsDirectoryName":  "logs",
    "NativeLibrariesDirectoryName":  "native",
    "TempDirectoryName":  "tmp",
    "EarlyExitWatchSeconds":  30
}
