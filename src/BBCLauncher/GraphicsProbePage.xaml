<Page
    x:Class="BBCLauncher.GraphicsProbePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#101010">

    <Grid>
        <Canvas x:Name="ProbeCanvas" Background="#202040" />
        <StackPanel VerticalAlignment="Bottom" Margin="32" Spacing="8">
            <TextBlock x:Name="ProbeStatus" Foreground="White" FontSize="22" />
            <Button Content="Run probe again" Click="OnRetryClicked" />
        </StackPanel>
    </Grid>
</Page>
