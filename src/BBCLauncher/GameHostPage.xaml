<Page
    x:Class="BBCLauncher.GameHostPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

    <Grid>
        <SwapChainPanel x:Name="RenderSurface" />

        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="32" Background="#AA000000" Padding="16">
            <TextBlock x:Name="TitleText"
                       Text="BBC Launcher"
                       FontSize="28"
                       Foreground="White"
                       Margin="0,0,0,8" />
            <TextBlock x:Name="StatusText"
                       Text="Starting presentation..."
                       FontSize="18"
                       Foreground="#CCCCCC"
                       TextWrapping="WrapWholeWords"
                       MaxWidth="860" />
            <TextBlock x:Name="StatsText"
                       Text=""
                       FontSize="14"
                       Foreground="#888888"
                       Margin="0,8,0,0"
                       TextWrapping="WrapWholeWords"
                       MaxWidth="860" />
        </StackPanel>
    </Grid>
</Page>
